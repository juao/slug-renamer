// slug-renamer.rc
// Compilar com: windres slug-renamer.rc -O coff -o slug-renamer.syso

#include <windows.h>

// Manifesto de execução (eleva para admin)
1 RT_MANIFEST "manifest.xml"

// Informações de versão do executável
VS_VERSION_INFO VERSIONINFO
  FILEVERSION     1,0,0,0
  PRODUCTVERSION  1,0,0,0
  FILEFLAGSMASK   VS_FFI_FILEFLAGSMASK
  FILEFLAGS       0
  FILEOS          VOS_NT_WINDOWS32
  FILETYPE        VFT_APP
  FILESUBTYPE     0
BEGIN
  BLOCK "StringFileInfo"
  BEGIN
    BLOCK "040904B0"
    BEGIN
      VALUE "CompanyName",      "Seu Nome\0"
      VALUE "FileDescription",  "Slug Renamer — Context Menu Shell Extension\0"
      VALUE "FileVersion",      "1.0.0.0\0"
      VALUE "InternalName",     "slug-renamer\0"
      VALUE "LegalCopyright",   "Copyright (c) 2025\0"
      VALUE "OriginalFilename", "slug-renamer.exe\0"
      VALUE "ProductName",      "Slug Renamer\0"
      VALUE "ProductVersion",   "1.0.0\0"
    END
  END
  BLOCK "VarFileInfo"
  BEGIN
    VALUE "Translation", 0x0409, 0x04B0
  END
END
